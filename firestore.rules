rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // RadioSync app data — path: artifacts/{appId}/public/data/{collection}/{doc}
    match /artifacts/{appId}/public/data/{collection}/{docId} {

      function isAdmin() {
        return request.auth != null && request.auth.token.admin == true;
      }

      // Self-service: employee borrows an available radio themselves
      function isSelfBorrow() {
        return resource.data.status == 'available'
            && request.resource.data.status == 'borrowed'
            && request.resource.data.name   == resource.data.name
            && request.resource.data.serial == resource.data.serial
            && request.resource.data.currentBorrower != null;
      }

      // Self-service: employee requests return of a radio they hold
      function isSelfReturnRequest() {
        return resource.data.status == 'borrowed'
            && request.resource.data.status == 'pending_return'
            && request.resource.data.name            == resource.data.name
            && request.resource.data.serial           == resource.data.serial
            && request.resource.data.currentBorrower  == resource.data.currentBorrower;
      }

      // Any anonymous-authenticated user can read all data
      allow read: if request.auth != null;

      // Equipment create: admin only (adding new equipment), must start available
      allow create: if request.auth != null && collection == 'equipment' && isAdmin()
                    && request.resource.data.keys().hasAll(['id', 'name', 'serial', 'status', 'updatedAt'])
                    && request.resource.data.status == 'available';

      // Equipment update: admins may perform any valid transition (approve return,
      // force recall, reassign, edit); employees may only self-service borrow or
      // request-return their own device
      allow update: if request.auth != null && collection == 'equipment'
                    && request.resource.data.keys().hasAll(['id', 'name', 'serial', 'status', 'updatedAt'])
                    && request.resource.data.status in ['available', 'borrowed', 'pending_return']
                    && (isAdmin() || isSelfBorrow() || isSelfReturnRequest());

      // Equipment delete: admin only
      allow delete: if request.auth != null && collection == 'equipment' && isAdmin();

      // Logs: create-only — audit trail cannot be modified or deleted
      allow create: if request.auth != null && collection == 'logs'
                    && request.resource.data.keys().hasAll(['id', 'equipId', 'empId', 'action', 'timestamp']);
      allow update, delete: if false;

      // Admin FCM tokens — write by any authenticated client, read by Cloud Functions (admin SDK bypasses rules)
      allow create, update: if request.auth != null
                            && collection == 'adminTokens'
                            && request.resource.data.keys().hasAll(['token', 'createdAt'])
                            && request.resource.data.token is string;
      allow delete: if request.auth != null && collection == 'adminTokens';
    }

    // Admin secret store (PIN hash + lockout state) — Cloud Functions Admin SDK
    // only (bypasses rules); fully blocked from every client.
    match /adminSecrets/{docId} {
      allow read, write: if false;
    }

    // Block all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
